# :heavy — the "everything" image for agent/fuzzer work.
#
# FROM :prebuilt (which already has /workspace/bun + bun-debug built).
#
#   - gh CLI                  (PRs, issues)
#   - databases               (Bun's test suite needs redis/postgres/mariadb)
#   - vendor/WebKit source    (JSC crash fixes need the source)
#   - Swift + Fuzzilli        (fuzzing)
#   - warm builds             (debug, debug-fuzz, release, release-asan)
#

# Use ARG so the per-arch CI jobs can point at :prebuilt-amd64 /
# :prebuilt-arm64 to build same-arch without cross-compilation.
ARG BASE_IMAGE=ghcr.io/oven-sh/bun-development-docker-image:prebuilt
FROM ${BASE_IMAGE}

# --- gh CLI ------------------------------------------------------------------

RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && \
    apt-get install -y --no-install-recommends gh && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# --- databases ---------------------------------------------------------------

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    redis-server \
    postgresql postgresql-contrib \
    mariadb-server \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/lib/postgresql/data /var/lib/mysql /var/lib/redis /var/run/postgresql && \
    chown -R postgres:postgres /var/lib/postgresql /var/run/postgresql && \
    chown -R mysql:mysql /var/lib/mysql && \
    PG_VERSION=$(ls -1 /usr/lib/postgresql | sort -V | tail -1) && \
    su postgres -c "/usr/lib/postgresql/$PG_VERSION/bin/initdb -D /var/lib/postgresql/data" && \
    mysql_install_db --user=mysql --datadir=/var/lib/mysql --auth-root-authentication-method=normal

# --- Swift toolchain ---------------------------------------------------------
#
# Swift's URL scheme is inconsistent: x86_64 debian12 builds have NO arch
# suffix in the path, but aarch64 builds DO. We derive the path slug instead
# of the arch name.

ARG SWIFT_VERSION=6.1
RUN case "$(uname -m)" in \
        aarch64|arm64) SWIFT_SLUG="debian12-aarch64" ;; \
        *)             SWIFT_SLUG="debian12" ;; \
    esac && \
    curl -fsSL "https://download.swift.org/swift-${SWIFT_VERSION}-release/${SWIFT_SLUG}/swift-${SWIFT_VERSION}-RELEASE/swift-${SWIFT_VERSION}-RELEASE-${SWIFT_SLUG}.tar.gz" \
    | tar xz --strip-components=2 -C /usr

# --- Fuzzilli ----------------------------------------------------------------

RUN git clone --depth 1 https://github.com/oven-sh/fuzzilli.git /opt/fuzzilli && \
    cd /opt/fuzzilli && \
    swift build -c release

WORKDIR /workspace/bun

# --- refresh source ----------------------------------------------------------
#
# :prebuilt's /workspace/bun is from its own build time. Pull before the
# WebKit grep and the build steps so everything below sees current main and
# all baked build dirs are warm against the same commit. Kept after the
# Swift/Fuzzilli layers so those stay cached across daily rebuilds.

RUN git pull --ff-only && \
    bun install && \
    bun install --cwd=test --ignore-scripts

# --- WebKit source -----------------------------------------------------------
#
# :prebuilt builds against precompiled WebKit artifacts but doesn't include
# the source tree. Agents fixing JSC crashes need it.

RUN WEBKIT_COMMIT=$(grep -oP 'WEBKIT_VERSION = "\K[0-9a-f]+' scripts/build/deps/webkit.ts) && \
    if [ -d vendor/WebKit/.git ]; then \
        cd vendor/WebKit && git fetch --depth 1 origin $WEBKIT_COMMIT && git checkout $WEBKIT_COMMIT; \
    else \
        git clone --depth 1 https://github.com/oven-sh/WebKit.git vendor/WebKit && \
        cd vendor/WebKit && git fetch --depth 1 origin $WEBKIT_COMMIT && git checkout $WEBKIT_COMMIT; \
    fi

# --- builds ------------------------------------------------------------------
#
# Warm caches for the profiles agents actually use, all against the
# already-pulled main:
#   build/debug/        — debug profile (ASAN on; debug-no-asan is separate)
#   build/debug-fuzz/   — debug + fuzzilli, fuzzer target
#   build/release/      — release profile
#   build/release-asan/ — release + ASAN
# The retry-once on debug papers over the occasional first-configure flake.

RUN (bun run build || bun run build) && \
    bun run build:debug:fuzzilli && \
    bun run build:release && \
    bun run build:asan && \
    rm -rf /tmp/*

# --- env for consumers -------------------------------------------------------

ENV FUZZILLI_CLI_PATH=/opt/fuzzilli/.build/release/FuzzilliCli
ENV BUN_REPO_PATH=/workspace/bun
ENV BUN_DEBUG_FUZZ=/workspace/bun/build/debug-fuzz/bun-debug

# Shared service startup script — downstream entrypoints source this.
COPY heavy-start-services.sh /opt/start-services.sh
RUN chmod +x /opt/start-services.sh

CMD ["/bin/bash"]
